{
  "name": "clinical-teal",
  "description": "Clinical research theme with white background and teal/medical accents",
  "use_case": "Clinical research presentations, medical conferences, grand rounds",
  "palette": {
    "background": "#ffffff",
    "text": "#1a202c",
    "heading": "#0d4f4f",
    "accent": "#0d9488",
    "accent_light": "#f0fdfa",
    "muted": "#64748b",
    "highlight": "#0891b2",
    "success": "#059669",
    "warning": "#d97706",
    "error": "#dc2626"
  },
  "typography": {
    "heading_font": "'Segoe UI', 'Helvetica Neue', Arial, sans-serif",
    "body_font": "'Segoe UI', 'Helvetica Neue', Arial, sans-serif",
    "code_font": "'Courier New', monospace",
    "heading_weight": "600",
    "body_weight": "400",
    "heading_size": "2rem",
    "body_size": "1.1rem",
    "caption_size": "0.85rem"
  },
  "spacing": {
    "slide_padding": "2rem 3rem",
    "section_gap": "1.5rem",
    "element_gap": "0.75rem"
  },
  "borders": {
    "divider": "1px solid #e2e8f0",
    "accent_bar": "3px solid #0d9488",
    "table_header": "2px solid #0d9488"
  },
  "footer": {
    "custom_footer_style": "margin-top: 1.5rem; font-size: 0.8rem; color: #64748b; display: flex; justify-content: space-between;",
    "positioning": "flow (margin-top), sits above Slidev built-in footer bar"
  },
  "slidev_config": {
    "theme": "none",
    "highlighter": "shiki",
    "css": "unocss"
  }
}
