{
  "name": "seminar-deep-dive",
  "mode": "SEMINAR",
  "description": "Departmental seminar with deep methodology and discussion (45-60 min)",
  "duration_minutes": { "min": 45, "max": 60 },
  "slide_count": 35,
  "sections": [
    {
      "name": "Introduction",
      "slides": [
        { "position": 1, "type": "title", "required": true, "content_focus": "Talk title, speaker bio, department, date" },
        { "position": 2, "type": "outline", "required": true, "content_focus": "Talk outline with timing estimates" },
        { "position": 3, "type": "motivation", "required": true, "content_focus": "Big picture motivation, clinical/scientific gap" },
        { "position": 4, "type": "background-1", "required": true, "content_focus": "Historical context and foundational work" },
        { "position": 5, "type": "background-2", "required": true, "content_focus": "Recent advances and current state of knowledge" },
        { "position": 6, "type": "background-3", "required": false, "content_focus": "Theoretical framework or conceptual model" }
      ]
    },
    {
      "name": "Research Program",
      "slides": [
        { "position": 7, "type": "research-overview", "required": true, "content_focus": "Overview of research program and aims" },
        { "position": 8, "type": "aim-1-intro", "required": true, "content_focus": "Specific Aim 1 rationale and hypothesis" },
        { "position": 9, "type": "aim-1-methods", "required": true, "content_focus": "Aim 1 study design and methods" },
        { "position": 10, "type": "aim-1-results-1", "required": true, "content_focus": "Aim 1 primary results" },
        { "position": 11, "type": "aim-1-results-2", "required": false, "content_focus": "Aim 1 secondary results or sensitivity analyses" },
        { "position": 12, "type": "aim-1-summary", "required": true, "content_focus": "Aim 1 key findings and implications" },
        { "position": 13, "type": "transition-1-2", "required": false, "content_focus": "Transition from Aim 1 to Aim 2" },
        { "position": 14, "type": "aim-2-intro", "required": true, "content_focus": "Specific Aim 2 rationale and hypothesis" },
        { "position": 15, "type": "aim-2-methods", "required": true, "content_focus": "Aim 2 study design and methods" },
        { "position": 16, "type": "aim-2-results-1", "required": true, "content_focus": "Aim 2 primary results" },
        { "position": 17, "type": "aim-2-results-2", "required": false, "content_focus": "Aim 2 secondary results" },
        { "position": 18, "type": "aim-2-summary", "required": true, "content_focus": "Aim 2 key findings and implications" },
        { "position": 19, "type": "transition-2-3", "required": false, "content_focus": "Transition from Aim 2 to Aim 3" },
        { "position": 20, "type": "aim-3-intro", "required": false, "content_focus": "Specific Aim 3 rationale (if applicable)" },
        { "position": 21, "type": "aim-3-methods", "required": false, "content_focus": "Aim 3 methods" },
        { "position": 22, "type": "aim-3-results", "required": false, "content_focus": "Aim 3 results" },
        { "position": 23, "type": "aim-3-summary", "required": false, "content_focus": "Aim 3 summary" }
      ]
    },
    {
      "name": "Synthesis",
      "slides": [
        { "position": 24, "type": "integrated-discussion", "required": true, "content_focus": "Cross-aim synthesis and integrated interpretation" },
        { "position": 25, "type": "comparison-literature", "required": true, "content_focus": "Comparison to existing literature" },
        { "position": 26, "type": "clinical-implications", "required": true, "content_focus": "Clinical or translational implications" },
        { "position": 27, "type": "methodological-innovations", "required": false, "content_focus": "Novel methods or analytical approaches" },
        { "position": 28, "type": "limitations", "required": true, "content_focus": "Limitations across studies" }
      ]
    },
    {
      "name": "Future Directions",
      "slides": [
        { "position": 29, "type": "ongoing-work", "required": true, "content_focus": "Current and ongoing studies" },
        { "position": 30, "type": "future-aims", "required": true, "content_focus": "Planned future research directions" },
        { "position": 31, "type": "funding-timeline", "required": false, "content_focus": "Funding status and research timeline" }
      ]
    },
    {
      "name": "Closing",
      "slides": [
        { "position": 32, "type": "conclusions", "required": true, "content_focus": "Key takeaways from entire program" },
        { "position": 33, "type": "acknowledgments", "required": true, "content_focus": "Lab members, collaborators, funding" },
        { "position": 34, "type": "publications", "required": false, "content_focus": "Key publications from research program" },
        { "position": 35, "type": "questions", "required": true, "content_focus": "Q&A slide with contact information" }
      ]
    }
  ]
}
