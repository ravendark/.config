{
  "id": "pattern-partnership",
  "name": "Partnership Proposal",
  "description": "Business partnership pitch: Mutual value, problem/solution, market fit.",
  "slide_count": 8,
  "deck_modes": ["PARTNERSHIP"],
  "slide_sequence": [
    {"position": 1, "slide_type": "cover", "required": true, "default_content": "cover-standard"},
    {"position": 2, "slide_type": "problem", "required": true, "default_content": "problem-statement"},
    {"position": 3, "slide_type": "solution", "required": true, "default_content": "solution-two-col"},
    {"position": 4, "slide_type": "market", "required": true, "default_content": "market-narrative"},
    {"position": 5, "slide_type": "traction", "required": true, "default_content": "traction-metrics"},
    {"position": 6, "slide_type": "why-us-now", "required": true, "default_content": "why-us-moat"},
    {"position": 7, "slide_type": "team", "required": false, "default_content": "team-two-col"},
    {"position": 8, "slide_type": "closing", "required": true, "default_content": "closing-cta"}
  ],
  "appendix_suggestions": ["appendix-competition", "appendix-roadmap"],
