{
  "id": "pattern-lightning-5",
  "name": "Lightning Talk (5 slides)",
  "description": "5-minute lightning talk format for conferences and meetups.",
  "slide_count": 5,
  "deck_modes": ["LIGHTNING"],
  "slide_sequence": [
    {"position": 1, "slide_type": "cover", "required": true, "default_content": "cover-standard"},
    {"position": 2, "slide_type": "problem", "required": true, "default_content": "problem-statement"},
    {"position": 3, "slide_type": "solution", "required": true, "default_content": "solution-demo"},
    {"position": 4, "slide_type": "traction", "required": true, "default_content": "traction-metrics"},
    {"position": 5, "slide_type": "ask", "required": true, "default_content": "ask-centered"}
  ],
  "appendix_suggestions": [],
  "constraints": {
    "max_main_slides": 7,
    "max_appendix_slides": 3,
    "max_bullets_per_slide": 3,
    "max_words_body": 20,
    "min_font_title_pt": 44,
    "min_font_body_pt": 28
  },
  "ordering_strategies": {
    "standard": [1, 2, 3, 4, 5],
    "demo-first": [1, 3, 2, 4, 5]
  }
}
